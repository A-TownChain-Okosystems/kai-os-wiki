// Skalierbare prozedurale Inhaltserzeugung

struct ProcGenerator {
    id: String,
    seed: u64,
    config: ProcConfig,
    generators: Vec<SubGenerator>,
    output_registry: Vec<ProcOutput>,
    quality_filter: QualityFilter
}

struct ProcConfig {
    determinism: bool,        // Same seed = same output
    density: f32,             // 0.0 (sparse) to 1.0 (dense)
    variety: f32,             // 0.0 (repetitive) to 1.0 (diverse)
    realism: f32,             // 0.0 (fantasy) to 1.0 (hard sci-fi)
    detail_level: u8,         // 1-10
    max_assets: u32,
    parallel_workers: u8
}

struct SubGenerator {
    id: String,
    type: String,             // "planet"|"star_system"|"biome"|"city"|"dungeon"|"quest"|"faction"|"flora"|"fauna"|"npc"|"texture"|"music"
    enabled: bool,
    seed_offset: u64,
    parameters: Map<String, f32>,
    last_output_count: u32,
    avg_quality: f32
}

struct ProcOutput {
    id: String,
    type: String,
    name: String,
    seed: u64,
    quality: f32,
    data: Map<String, String>,
    dependencies: Vec<String>,
    verified: bool
}

struct QualityFilter {
    min_quality: f32,
    max_duplicates: u32,
    diversity_threshold: f32,
    canon_compliance: bool,
    auto_reject: Vec<String>  // patterns to reject
}

fn proc_create(seed: u64) -> ProcGenerator {
    ProcGenerator {
        id: generate_id("PROC"),
        seed: seed,
        config: ProcConfig { determinism: true, density: 0.5, variety: 0.8, realism: 0.6, detail_level: 5, max_assets: 10000, parallel_workers: 4 },
        generators: vec![
            SubGenerator { id: "planet", type: "planet", enabled: true, seed_offset: 0, parameters: Map::new(), last_output_count: 0, avg_quality: 0.0 },
            SubGenerator { id: "star", type: "star_system", enabled: true, seed_offset: 1000, parameters: Map::new(), last_output_count: 0, avg_quality: 0.0 },
            SubGenerator { id: "biome", type: "biome", enabled: true, seed_offset: 2000, parameters: Map::new(), last_output_count: 0, avg_quality: 0.0 },
            SubGenerator { id: "city", type: "city", enabled: true, seed_offset: 3000, parameters: Map::new(), last_output_count: 0, avg_quality: 0.0 },
            SubGenerator { id: "dungeon", type: "dungeon", enabled: true, seed_offset: 4000, parameters: Map::new(), last_output_count: 0, avg_quality: 0.0 },
            SubGenerator { id: "quest", type: "quest", enabled: true, seed_offset: 5000, parameters: Map::new(), last_output_count: 0, avg_quality: 0.0 },
            SubGenerator { id: "faction", type: "faction", enabled: true, seed_offset: 6000, parameters: Map::new(), last_output_count: 0, avg_quality: 0.0 },
            SubGenerator { id: "flora", type: "flora", enabled: true, seed_offset: 7000, parameters: Map::new(), last_output_count: 0, avg_quality: 0.0 },
            SubGenerator { id: "fauna", type: "fauna", enabled: true, seed_offset: 8000, parameters: Map::new(), last_output_count: 0, avg_quality: 0.0 }
        ],
        output_registry: Vec::new(),
        quality_filter: QualityFilter { min_quality: 0.7, max_duplicates: 5, diversity_threshold: 0.6, canon_compliance: true, auto_reject: Vec::new() }
    }
}

fn proc_generate(gen_id: String, type_: String, count: u32) -> Vec<ProcOutput> {
    let g = get_generator(gen_id);
    let gen = g.generators.iter_mut().find(|x| x.type == type_);
    if let Some(sub) = gen {
        if !sub.enabled { return Vec::new(); }
        let mut results = Vec::new();
        for i in 0..count {
            let local_seed = g.seed + sub.seed_offset + i as u64;
            let output = match type_ {
                "planet" => gen_planet(local_seed, g.config),
                "star_system" => gen_star_system(local_seed, g.config),
                "biome" => gen_biome(local_seed, g.config),
                "city" => gen_city(local_seed, g.config),
                "dungeon" => gen_dungeon(local_seed, g.config),
                "quest" => gen_quest(local_seed, g.config),
                "faction" => gen_faction(local_seed, g.config),
                "flora" => gen_flora(local_seed, g.config),
                "fauna" => gen_fauna(local_seed, g.config),
                _ => continue
            };
            // Quality filter
            if output.quality >= g.quality_filter.min_quality {
                // Duplicate check
                if !is_duplicate(output, g, g.quality_filter.max_duplicates) {
                    results.push(output);
                }
            }
        }
        sub.last_output_count = results.len() as u32;
        sub.avg_quality = results.iter().map(|r| r.quality).sum::<f32>() / results.len().max(1) as f32;
        g.output_registry.extend(results.clone());
        return results;
    }
    Vec::new()
}

fn gen_planet(seed: u64, config: ProcConfig) -> ProcOutput {
    let rng = SeededRng::new(seed);
    let types = ["terrestrial", "gas_giant", "ice", "ocean", "desert", "jungle", "volcanic", "crystal"];
    let biomes = ["forest", "desert", "tundra", "swamp", "mountain", "plains", "coastal", "arctic"];
    ProcOutput {
        id: generate_id("PL"),
        type: "planet",
        name: "Planet-" + seed.to_string(),
        seed: seed,
        quality: rng.range(0.6, 0.95),
        data: map {
            "type" => types[rng.int(0, 7)],
            "biome" => biomes[rng.int(0, 7)],
            "gravity" => rng.float(0.3, 2.5),
            "atmosphere" => rng.choice(["nitrogen_oxygen", "carbon_dioxide", "methane", "helium"]),
            "temperature" => rng.float(-200.0, 300.0),
            "population" => rng.int(0, 1000000000),
            "tech_level" => rng.int(0, 10),
            "moons" => rng.int(0, 8)
        },
        dependencies: Vec::new(),
        verified: false
    }
}

fn gen_star_system(seed: u64, config: ProcConfig) -> ProcOutput {
    let rng = SeededRng::new(seed);
    ProcOutput {
        id: generate_id("SS"),
        type: "star_system",
        name: "System-" + seed.to_string(),
        seed: seed,
        quality: rng.range(0.65, 0.98),
        data: map {
            "star_type" => rng.choice(["main_sequence", "red_giant", "white_dwarf", "neutron", "binary"]),
            "star_count" => rng.int(1, 3),
            "planet_count" => rng.int(0, 12),
            "asteroid_belts" => rng.int(0, 3),
            "age_billion_years" => rng.float(0.5, 13.0),
            "luminosity" => rng.float(0.01, 100.0)
        },
        dependencies: Vec::new(),
        verified: false
    }
}

fn gen_dungeon(seed: u64, config: ProcConfig) -> ProcOutput {
    let rng = SeededRng::new(seed);
    let room_count = rng.int(5, 50) * config.detail_level as u32;
    ProcOutput {
        id: generate_id("DG"),
        type: "dungeon",
        name: "Dungeon-" + seed.to_string(),
        seed: seed,
        quality: rng.range(0.7, 0.97),
        data: map {
            "rooms" => room_count,
            "floors" => rng.int(1, 10),
            "difficulty" => rng.int(1, 20),
            "theme" => rng.choice(["crypt", "cave", "ruins", "temple", "fortress", "lair"]),
            "traps" => rng.int(0, room_count / 3),
            "secrets" => rng.int(0, room_count / 5),
            "boss" => rng.bool(),
            "loot_tier" => rng.choice(["common", "uncommon", "rare", "legendary"])
        },
        dependencies: Vec::new(),
        verified: false
    }
}

fn gen_quest(seed: u64, config: ProcConfig) -> ProcOutput {
    let rng = SeededRng::new(seed);
    ProcOutput {
        id: generate_id("QS"),
        type: "quest",
        name: "Quest-" + seed.to_string(),
        seed: seed,
        quality: rng.range(0.6, 0.92),
        data: map {
            "type" => rng.choice(["main", "side", "daily", "dynamic", "story"]),
            "objective" => rng.choice(["fetch", "kill", "escort", "explore", "puzzle", "defend", "collect"]),
            "difficulty" => rng.int(1, 10),
            "rewards" => rng.choice(["gold", "item", "experience", "reputation", "unlock"]),
            "min_level" => rng.int(1, 50),
            "estimated_time_min" => rng.int(5, 120),
            "branches" => rng.int(0, 5)
        },
        dependencies: Vec::new(),
        verified: false
    }
}

