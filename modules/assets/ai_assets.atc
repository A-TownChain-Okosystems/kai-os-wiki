# ATC AD-78 — AI Asset Management
# Genesis Engine — Verwaltung von KI-Ressourcen
# Standard: AD-78

enum AIAssetType:
    LLM_PROMPT         # Prompt Templates
    DIALOG_DATA        # Dialog-Bäume und Optionen
    VOICE_MODEL        # TTS / STT Modelle
    NPC_PERSONALITY    # Charakter-Persönlichkeiten
    EMBEDDING          # Vektor-Embeddings
    BEHAVIOR_TREE      # KI-Entscheidungsbäume
    TRAINING_DATA      # Fine-Tuning Datensätze
    MODEL_WEIGHTS      # Neuronale Netzwerke

struct AIAsset:
    name: String
    asset_type: AIAssetType
    data: ByteArray
    metadata: Map<String, Variant>
    version: String
    size_bytes: Int64
    model_format: String       # "onnx" | "pt" | "gguf" | "safetensors"
    context_length: Int32      # Für LLMs
    embedding_dim: Int32       # Für Embeddings

struct LLMPrompt:
    name: String
    template: String           # "You are {character_name} from {world}..."
    variables: Array<String>   # ["character_name", "world"]
    system_prompt: String
    max_tokens: Int32
    temperature: Float
    model_hint: String         # "gpt-4" | "llama-3" | "local"

struct NPCPersonality:
    name: String
    traits: Array<String>      # ["friendly", "cautious", "humorous"]
    speech_style: String       # "formal" | "casual" | "dialect"
    values: Array<String>      # ["honor", "freedom", "knowledge"]
    fears: Array<String>
    goals: Array<String>
    backstory: String
    voice_model: String        # Referenz zu Voice Model

func load_ai_asset(path: String, atype: AIAssetType) -> AIAsset:
    data = read_binary(path)
    asset = AIAsset {
        name: get_filename(path),
        asset_type: atype,
        data: data,
        metadata: {},
        version: "1.0.0",
        size_bytes: len(data),
        model_format: detect_format(data),
        context_length: 0,
        embedding_dim: 0
    }
    # Parse basierend auf Typ
    match atype:
        LLM_PROMPT:
            parse_prompt_metadata(asset)
        DIALOG_DATA:
            parse_dialog_data(asset)
        VOICE_MODEL:
            parse_voice_model(asset)
        NPC_PERSONALITY:
            parse_personality(asset)
        EMBEDDING:
            parse_embedding(asset)
        BEHAVIOR_TREE:
            parse_behavior_tree(asset)
    log_info(f"AI Asset loaded: {asset.name} ({asset.size_bytes} bytes, {atype})")
    return asset

func create_npc_personality(name: String, traits: Array<String>) -> NPCPersonality:
    return NPCPersonality {
        name: name,
        traits: traits,
        speech_style: "casual",
        values: [],
        fears: [],
        goals: [],
        backstory: "",
        voice_model: ""
    }

func load_voice_model(path: String) -> AIAsset:
    asset = load_ai_asset(path, VOICE_MODEL)
    # Voice Model Meta-Daten
    asset.metadata["sample_rate"] = 22050
    asset.metadata["language"] = "en"
    asset.metadata["voice_id"] = hash(path)
    return asset

func load_embeddings(path: String) -> AIAsset:
    asset = load_ai_asset(path, EMBEDDING)
    # Embedding Dimension und Anzahl
    asset.embedding_dim = detect_embedding_dim(asset.data)
    asset.metadata["vector_count"] = len(asset.data) / (asset.embedding_dim * 4)  # float32
    return asset

# KI-Asset Hot-Swap — Modelle zur Laufzeit austauschen
func hot_swap_model(old: AIAsset, new_path: String) -> AIAsset:
    new_asset = load_ai_asset(new_path, old.asset_type)
    # Atomic swap — kein Frame Drop
    atomic_swap(old, new_asset)
    log_info(f"AI Model hot-swapped: {old.name} → {new_asset.name}")
    return new_asset

# Prompt Versioning — mehrere Versionen eines Prompts verwalten
struct PromptVersion:
    version: String
    template: String
    performance_score: Float    # Wie gut funktioniert der Prompt
    a_b_test_active: Bool

func version_prompt(name: String, new_template: String) -> PromptVersion:
    return PromptVersion {
        version: next_version(),
        template: new_template,
        performance_score: 0.0,
        a_b_test_active: false
    }
